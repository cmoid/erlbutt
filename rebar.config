{require_otp_vsn, "R?21"}.

%% Tell rebar about this directory's structure
{lib_dirs, ["apps", "deps"]}.
{sub_dirs, ["apps/*"]}.

%% Build a release when compiling
%%{post_hooks,[{compile, "./relx"}]}.

%% These deps are temporary forks, that needed minor tweaks to make usable,
%% or are not actively maintained
%% TODO: push changes upstream or otherwise resolve
{deps, [
    {ranch, "2.1.0", {git, "https://github.com/ninenines/ranch", {tag, "2.1.0"}}},
    {enacl, "1.1.1", {git, "https://github.com/cmoid/enacl", {branch, "moid-v1.1.1"}}}
]}.
{plugins, [rebar3_auto]}.
{ct_opts, [{sname, erlbutt_ct},
           {dir, ["apps/ssb/test", "apps/plumtree/test", "apps/silkpurse/test"]}]}.
%% Base release = the floor for ALL profiles: relx UNIONS each profile's app
%% list with this one, so a profile can only ADD apps, never subtract.  Hence
%% anything here lands in prod too.  syntax_tools + tools are here (not just in
%% devpkg) because distel/maxbutt need them on the node path for the local
%% `make rel` workflow, and tools (fprof/eprof/xref) is useful for remsh-time
%% profiling of a prod node.  The GUI stack (debugger, observer, wx) is NOT
%% here — devpkg adds it.
{relx, [{release, { ssb, {git, short} },
         [ssb,
          plumtree,
          silkpurse,
          runtime_tools,
          syntax_tools,
          tools]},

        {sys_config_src, "./config/sys.config.src"},
        {vm_args_src, "./config/vm.args.src"},

        {extended_start_script, true},

        {overlay_vars, "config/default.vars"},
        {overlay, [
                   {template, "config/ssb.cfg", "ssb.cfg"}
                  ]}

]
}.

{profiles, [%% Fast local iteration: symlinked beams, system-installed ERTS.
            {dev, [{erl_opts, [debug_info]},
                   {relx, [{dev_mode, true},
                            {include_erts, false}]}]
            },
            %% Distributable developer package: bundled ERTS, debug-instrumented
            %% beams, source code, and the GUI stack for live development with
            %% maxbutt.  A profile's release tuple REPLACES the base app list
            %% (it does not union), so this must enumerate the full set: the
            %% base apps plus debugger + observer.
            {devpkg, [{erl_opts, [debug_info]},
                      {relx, [{release, {ssb, {git, short}},
                               [ssb, plumtree, silkpurse, runtime_tools,
                                syntax_tools, tools, debugger, observer]},
                              {vm_args_src, "./config/vm.args.devpkg"},
                              {dev_mode, false},
                              {include_erts, true},
                              {include_src, true},
                              {debug_info, keep}]}]
            },
            %% Production package: bundled ERTS, stripped beams, no source, no
            %% GUI stack.  Inherits the base app list (no release override —
            %% relx can't subtract, so the base IS the minimal prod set).
            {prod, [{erl_opts, [no_debug_info, warnings_as_errors]},
                    {relx, [{vm_args_src, "./config/vm.args.prod"},
                            {dev_mode, false},
                            {include_erts, true},
                            {include_src, false},
                            {debug_info, strip}]}]
            }]
}.
