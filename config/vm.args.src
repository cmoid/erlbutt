## Local development node (used by `make rel`).  syntax_tools and tools are
## bundled in the release now, so no system -pa is needed for distel.
-name erlbutt@localhost
-setcookie erlbutt
-pa ${HOME}/code/erlbutt/_build/default/lib/ssb/ebin
-pa ${HOME}/code/erlbutt/_build/test/extras/test
-pa ${HOME}/code/maxbutt/ebin
